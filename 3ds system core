#include <3ds.h>
#include <stdio.h>

int main(void) {
    gfxInitDefault(); // Инициализация графики
    consoleInit(GFX_TOP, NULL); // Консоль на верхнем экране

    while (aptMainLoop()) {
        hidScanInput(); // Опрашиваем ввод
        u32 kDown = hidKeysDown();

        // Выводим текст
        printf("\x1b[2;0HHello 3DS ARM11!\n");
        printf("Press START to exit.\n");

        // Мигаем светодиодом
        if (kDown & KEY_A) {
            gpioWrite(GPIO_LED_RED, 1);
            svcSleepThread(500000000LL); // 0.5 с
            gpioWrite(GPIO_LED_RED, 0);
            svcSleepThread(500000000LL);
        }

        if (kDown & KEY_START) break; // Выход по START

        gfxFlushBuffers();
        gfxSwapBuffers();
        gspWaitForVBlank();
    }

    gfxExit();
    return 0;
}
